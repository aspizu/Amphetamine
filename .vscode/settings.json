{
  "editor.formatOnSave": true,
  "editor.formatOnSaveMode": "file",
  "files.readonlyInclude": {
    "**/pnpm-lock.yaml": true,
    "**/dist/**": true,
    "**/*.gen.*": true
  },
  "editor.rulers": [96],
  "[typescript]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "oxc.oxc-vscode"
  }
}
