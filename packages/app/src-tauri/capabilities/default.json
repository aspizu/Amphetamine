{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "enables the default permissions",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-execute",
    "fs:deny-default",
    "fs:allow-appcache-read-recursive",
    "fs:allow-appcache-write-recursive"
  ]
}
