{
  "$schema": "./node_modules/oxfmt/configuration_schema.json",
  "printWidth": 96,
  "semi": false,
  "bracketSpacing": false,
  "sortImports": true,
  "sortTailwindcss": {
    "stylesheet": "packages/client/src/styles/global.css",
    "functions": ["cva", "cn"]
  },
  "sortPackageJson": true,
  "ignorePatterns": [
    "node_modules",
    "openmpt",
    "pnpm-lock.yaml",
    "packages/*/dist",
    "packages/*/node_modules",
    "packages/client/src/routeTree.gen.ts"
  ]
}
